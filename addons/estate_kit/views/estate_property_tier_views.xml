<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="estate_property_tier_view_list" model="ir.ui.view">
        <field name="name">estate.property.tier.list</field>
        <field name="model">estate.property.tier</field>
        <field name="arch" type="xml">
            <list string="Тир-лист" editable="bottom">
                <field name="priority" widget="handle"/>
                <field name="property_id"/>
                <field name="user_id"/>
                <field name="role"/>
                <field name="date_added"/>
                <field name="note" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="estate_property_tier_view_form" model="ir.ui.view">
        <field name="name">estate.property.tier.form</field>
        <field name="model">estate.property.tier</field>
        <field name="arch" type="xml">
            <form string="Тир-лист">
                <sheet>
                    <group>
                        <group>
                            <field name="property_id"/>
                            <field name="user_id"/>
                            <field name="role"/>
                        </group>
                        <group>
                            <field name="priority"/>
                            <field name="date_added"/>
                        </group>
                    </group>
                    <group>
                        <field name="note" placeholder="Почему объект в приоритете..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="estate_property_tier_action" model="ir.actions.act_window">
        <field name="name">Тир-лист</field>
        <field name="res_model">estate.property.tier</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'default_user_id': uid}</field>
    </record>
</odoo>
