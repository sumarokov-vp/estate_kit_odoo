<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Quick create form for CRM Kanban (incoming call from buyer) -->
    <record id="crm_lead_view_form_quick_create_estate" model="ir.ui.view">
        <field name="name">crm.lead.form.quick_create.estate</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.quick_create_opportunity_form"/>
        <field name="arch" type="xml">
            <!-- Hide fields not needed during incoming buyer call -->
            <xpath expr="//div[field[@name='commercial_partner_id']]" position="replace"/>
            <xpath expr="//div[field[@name='partner_id']]" position="replace"/>
            <xpath expr="//div[field[@name='name']]" position="replace"/>
            <xpath expr="//div[field[@name='email_from']]" position="replace"/>
            <xpath expr="//div[div/field[@name='expected_revenue']]" position="replace"/>

            <!-- Add estate-specific fields -->
            <xpath expr="//group" position="inside">
                <div colspan="2" class="d-flex align-items-center">
                    <i class="fa fa-user" title="Имя клиента"/>
                    <field name="contact_name" nolabel="1" placeholder="Имя клиента" class="o_field_highlight w-100 mb-0" required="1"/>
                </div>
                <div colspan="2" class="d-flex align-items-center">
                    <i class="fa fa-handshake-o" title="Тип сделки"/>
                    <field name="search_deal_type" nolabel="1" placeholder="Тип сделки" class="o_field_highlight w-100 mb-0"/>
                </div>
                <div colspan="2" class="d-flex align-items-center">
                    <i class="fa fa-home" title="Тип объекта"/>
                    <field name="search_property_type" nolabel="1" placeholder="Тип объекта" class="o_field_highlight w-100 mb-0"/>
                </div>
            </xpath>
        </field>
    </record>

    <record id="crm_lead_view_form_inherit_estate" model="ir.ui.view">
        <field name="name">crm.lead.form.inherit.estate</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <!-- Disable statusbar clicking (stages managed by action buttons only) -->
            <xpath expr="//field[@name='stage_id']" position="attributes">
                <attribute name="options">{'clickable': '0', 'fold_field': 'fold'}</attribute>
            </xpath>

            <!-- Replace standard Won/Lost with dynamic action buttons -->
            <xpath expr="//button[@name='action_set_won_rainbowman']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//button[@name='%(crm.crm_lead_lost_action)d']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Dynamic button: Подобрать объекты (in header, visible on "New" stage) -->
            <xpath expr="//button[@name='action_set_won_rainbowman']" position="after">
                <button name="action_match_properties" type="object"
                    string="Подобрать объекты" class="oe_highlight"
                    invisible="stage_id != %(crm.stage_lead1)d"/>
            </xpath>

            <!-- Hide standard Salesperson field (replaced by isa_user_id) -->
            <xpath expr="//field[@name='user_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide probability section -->
            <xpath expr="//div[@id='probability']/.." position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide email from header (opportunity view) — moved to Contacts tab -->
            <xpath expr="//group[@name='opportunity_partner']//label[@for='email_from']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//group[@name='opportunity_partner']//field[@name='email_from']/.." position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Add email to Contacts tab -->
            <xpath expr="//page[@name='lead']//field[@name='function']" position="after">
                <field name="email_from" string="Эл. почта" widget="email"/>
            </xpath>

            <!-- Hide Marketing group inside Contacts tab -->
            <xpath expr="//page[@name='lead']//field[@name='campaign_id']/.." position="replace"/>

            <!-- Smart button: Подборки -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button class="oe_stat_button" icon="fa-handshake-o"
                    name="%(estate_deal_action)d" type="action"
                    context="{'search_default_lead_id': id}">
                    <field name="match_count" string="Подборки" widget="statinfo"/>
                </button>
            </xpath>

            <!-- Hide original Notes tab (recreated below in correct position) -->
            <xpath expr="//page[@name='internal_notes']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Tab 1: Потребность (before hidden internal_notes = first position) -->
            <xpath expr="//page[@name='internal_notes']" position="before">
                <page string="Потребность" name="search_criteria">
                    <group>
                        <group>
                            <field name="search_deal_type"/>
                            <field name="search_property_type"/>
                            <field name="search_city_id"/>
                            <field name="search_district_ids" widget="many2many_tags"/>
                        </group>
                        <group>
                            <field name="search_rooms_min"/>
                            <field name="search_rooms_max"/>
                            <field name="search_price_min"/>
                            <field name="search_price_max"/>
                            <field name="company_currency" invisible="1"/>
                            <field name="search_area_min"/>
                            <field name="search_area_max"/>
                        </group>
                    </group>
                    <group string="Примечания по поиску">
                        <field name="search_notes" nolabel="1" colspan="2"/>
                    </group>
                </page>
            </xpath>

            <!-- Tabs 3-6 after Контакты: Недвижимость, Маркетинг, Заметки, Telegram -->
            <xpath expr="//page[@name='lead']" position="after">
                <!-- Вкладка: Недвижимость -->
                <page string="Подбор" name="estate_info">
                    <group>
                        <group>
                            <field name="property_id" readonly="1"/>
                        </group>
                    </group>
                    <field name="match_ids" readonly="1"
                        style="max-height: 600px; overflow-y: auto; display: block;">
                        <list create="0" delete="0" edit="0" limit="20" open_form_view="True">
                            <field name="property_id" string="Объект"/>
                            <field name="property_price" string="Цена"/>
                            <field name="marketing_pool_score_display" string="MPS"/>
                            <field name="stage_id" widget="badge"/>
                            <field name="viewed_date" string="Дата просмотра"/>
                        </list>
                    </field>
                    <group>
                        <field name="last_matching_date" readonly="1"/>
                    </group>
                    <group string="Ответственные">
                        <group>
                            <field name="isa_user_id"/>
                            <field name="buyer_agent_id"/>
                            <field name="transaction_coordinator_id"/>
                        </group>
                    </group>
                </page>

                <!-- Вкладка: Маркетинг -->
                <page string="Маркетинг" name="marketing">
                    <group>
                        <group>
                            <field name="campaign_id"/>
                            <field name="medium_id"/>
                            <field name="source_id"/>
                            <field name="referred"/>
                        </group>
                    </group>
                </page>

                <!-- Вкладка: Заметки -->
                <page string="Заметки" name="notes_estate">
                    <field name="description" placeholder="Добавьте заметки..." options="{'collaborative': true}"/>
                </page>

                <!-- Вкладка: Telegram -->
                <page string="Telegram" name="deeplink">
                    <group>
                        <group>
                            <field name="lead_code" readonly="1"/>
                            <field name="deeplink_url" readonly="1" widget="CopyClipboardChar"/>
                        </group>
                        <group>
                            <field name="bot_connected"/>
                            <field name="telegram_user_id" readonly="1"/>
                            <field name="last_bot_activity" readonly="1"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
