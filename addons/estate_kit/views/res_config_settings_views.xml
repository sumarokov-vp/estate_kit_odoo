<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.estate_kit</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Estate Kit" string="Estate Kit" name="estate_kit">
                    <block title="Регистрация в MLS" name="estate_kit_registration">
                        <setting string="Регистрация" help="Отправьте заявку на подключение к MLS">
                            <field name="estate_kit_is_registered" invisible="1"/>
                            <field name="estate_kit_reg_request_code" invisible="1"/>
                            <!-- Состояние 1: Форма регистрации (нет активной заявки) -->
                            <div class="content-group" invisible="estate_kit_reg_status in ('pending', 'pending_update')">
                                <div class="row mt16">
                                    <label for="estate_kit_api_url" class="col-lg-3 o_light_label"/>
                                    <field name="estate_kit_api_url" class="col-lg-6" placeholder="https://api.estatekit.kz/api/v1" required="True"/>
                                </div>
                                <div class="row mt16">
                                    <label for="estate_kit_reg_company_name" class="col-lg-3 o_light_label"/>
                                    <field name="estate_kit_reg_company_name" class="col-lg-6" placeholder="Название компании" required="True"/>
                                </div>
                                <div class="row mt16">
                                    <label for="estate_kit_reg_email" class="col-lg-3 o_light_label"/>
                                    <field name="estate_kit_reg_email" class="col-lg-6" placeholder="email@example.com" required="True"/>
                                </div>
                                <div class="row mt16">
                                    <label for="estate_kit_reg_phone" class="col-lg-3 o_light_label"/>
                                    <field name="estate_kit_reg_phone" class="col-lg-6" placeholder="+7 (777) 123-45-67"/>
                                </div>
                                <div class="mt16 d-flex gap-2">
                                    <button name="action_register_mls" type="object" string="Отправить заявку" class="btn-primary"/>
                                    <button name="action_update_tenant_data" type="object" string="Обновить данные" class="btn-secondary" invisible="not estate_kit_is_registered"/>
                                </div>
                            </div>
                            <!-- Состояние 2: Заявка на рассмотрении (pending или pending_update) -->
                            <div class="content-group" invisible="estate_kit_reg_status not in ('pending', 'pending_update')">
                                <div class="row mt16">
                                    <label for="estate_kit_reg_company_name" class="col-lg-3 o_light_label"/>
                                    <field name="estate_kit_reg_company_name" class="col-lg-6" readonly="True"/>
                                </div>
                                <div class="row mt16">
                                    <label for="estate_kit_reg_email" class="col-lg-3 o_light_label"/>
                                    <field name="estate_kit_reg_email" class="col-lg-6" readonly="True"/>
                                </div>
                                <div class="row mt16">
                                    <label for="estate_kit_reg_status" class="col-lg-3 o_light_label"/>
                                    <field name="estate_kit_reg_status" class="col-lg-6"/>
                                </div>
                                <div class="mt16">
                                    <button name="action_check_registration_status" type="object" string="Проверить статус" class="btn-secondary"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                    <block title="Telegram-бот" name="estate_kit_telegram_bot">
                        <setting string="Бот для клиентов" help="Username Telegram-бота для генерации deeplink в лидах">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="estate_kit_customer_bot_username" class="col-lg-3 o_light_label"/>
                                    <field name="estate_kit_customer_bot_username" class="col-lg-6" placeholder="estate_kit_customer_bot"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                    <block title="Яндекс Карты" name="estate_kit_yandex_maps">
                        <setting string="Яндекс Геокодер" help="API-ключ для геокодирования и отображения карт">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="estate_kit_yandex_geocoder_api_key" class="col-lg-3 o_light_label"/>
                                    <field name="estate_kit_yandex_geocoder_api_key" class="col-lg-6" placeholder="API-ключ" password="True"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                    <block title="AI-скоринг" name="estate_kit_ai_scoring">
                        <setting string="Anthropic Claude API" help="API-ключ для автоматической оценки объектов с помощью AI">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="estate_kit_anthropic_api_key" class="col-lg-3 o_light_label"/>
                                    <field name="estate_kit_anthropic_api_key" class="col-lg-6" placeholder="sk-ant-..." password="True"/>
                                </div>
                                <div class="row mt16">
                                    <label for="estate_kit_anthropic_model" class="col-lg-3 o_light_label"/>
                                    <field name="estate_kit_anthropic_model" class="col-lg-6" placeholder="claude-sonnet-4-5-20241022"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                    <block title="Комиссия" name="estate_kit_commission">
                        <setting string="Ставки комиссии" help="Минимальная комиссия агентства и допустимый коридор скидки от listing_price">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="estate_kit_min_commission_percent" class="col-lg-3 o_light_label"/>
                                    <field name="estate_kit_min_commission_percent" class="col-lg-3"/>
                                    <span class="col-lg-6 text-muted small">Минимальная комиссия агентства (%)</span>
                                </div>
                                <div class="row mt16">
                                    <label for="estate_kit_max_discount_percent" class="col-lg-3 o_light_label"/>
                                    <field name="estate_kit_max_discount_percent" class="col-lg-3"/>
                                    <span class="col-lg-6 text-muted small">Макс. допустимое снижение цены сделки от listing_price (%)</span>
                                </div>
                            </div>
                        </setting>
                    </block>
                    <block title="Парсинг Krisha.kz" name="estate_kit_krisha_parser">
                        <setting string="Импорт объектов" help="Фоновая задача периодически импортирует объекты с Krisha.kz по одной ссылке поиска">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="estate_kit_krisha_search_url" class="col-lg-3 o_light_label"/>
                                    <field name="estate_kit_krisha_search_url" class="col-lg-6" placeholder="https://krisha.kz/prodazha/kvartiry/almaty/?das[price][to]=50000000"/>
                                </div>
                                <div class="row mt16">
                                    <label for="estate_kit_krisha_import_limit" class="col-lg-3 o_light_label"/>
                                    <field name="estate_kit_krisha_import_limit" class="col-lg-3"/>
                                    <span class="col-lg-6 text-muted small">Максимум объектов за один запуск фоновой задачи</span>
                                </div>
                            </div>
                        </setting>
                    </block>
                    <block title="Маркетинговый пул" name="estate_kit_marketing_pool">
                        <setting string="Размер и пороги" help="Параметры формирования маркетингового пула">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="estate_kit_pool_max_size" class="col-lg-3 o_light_label"/>
                                    <field name="estate_kit_pool_max_size" class="col-lg-3"/>
                                    <span class="col-lg-6 text-muted small">Если подходящих объектов меньше — в пуле будет столько, сколько набралось</span>
                                </div>
                                <div class="row mt16">
                                    <label for="estate_kit_pool_min_price_score" class="col-lg-3 o_light_label"/>
                                    <field name="estate_kit_pool_min_price_score" class="col-lg-2"/>
                                    <span class="col-lg-7 text-muted small">Мин. балл конкурентности цены. Ниже порога → объект не попадает в пул</span>
                                </div>
                                <div class="row mt16">
                                    <label for="estate_kit_pool_min_quality_score" class="col-lg-3 o_light_label"/>
                                    <field name="estate_kit_pool_min_quality_score" class="col-lg-2"/>
                                    <span class="col-lg-7 text-muted small">Мин. балл качества объекта. Ниже порога → объект не попадает в пул</span>
                                </div>
                                <div class="row mt16">
                                    <label for="estate_kit_pool_min_listing_score" class="col-lg-3 o_light_label"/>
                                    <field name="estate_kit_pool_min_listing_score" class="col-lg-2"/>
                                    <span class="col-lg-7 text-muted small">Мин. балл качества карточки. Ниже порога → объект не попадает в пул</span>
                                </div>
                                <div class="row mt16">
                                    <label for="estate_kit_pool_inclusion_threshold" class="col-lg-3 o_light_label"/>
                                    <field name="estate_kit_pool_inclusion_threshold" class="col-lg-3"/>
                                    <span class="col-lg-6 text-muted small">Минимальный MPS для автоматического включения в пул</span>
                                </div>
                                <div class="row mt16">
                                    <label for="estate_kit_pool_exclusion_threshold" class="col-lg-3 o_light_label"/>
                                    <field name="estate_kit_pool_exclusion_threshold" class="col-lg-3"/>
                                    <span class="col-lg-6 text-muted small">MPS ниже этого значения → исключение из пула. Разница с порогом включения = гистерезис</span>
                                </div>
                            </div>
                        </setting>
                        <setting string="Веса формулы" help="MPS = AI-скоринг × вес скоринга + тир-бонус × вес тир-листов">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="estate_kit_pool_scoring_weight" class="col-lg-3 o_light_label"/>
                                    <field name="estate_kit_pool_scoring_weight" class="col-lg-3"/>
                                    <span class="col-lg-6 text-muted small">Сумма с весом тир-листов должна = 1.0</span>
                                </div>
                                <div class="row mt16">
                                    <label for="estate_kit_pool_tier_weight" class="col-lg-3 o_light_label"/>
                                    <field name="estate_kit_pool_tier_weight" class="col-lg-3"/>
                                    <span class="col-lg-6 text-muted small">Сумма с весом скоринга должна = 1.0</span>
                                </div>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
