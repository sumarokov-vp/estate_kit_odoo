<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="estate_kit_log_view_list" model="ir.ui.view">
        <field name="name">estate.kit.log.list</field>
        <field name="model">estate.kit.log</field>
        <field name="arch" type="xml">
            <list string="Логи" create="false" edit="false" delete="false">
                <field name="timestamp_display" string="Время"/>
                <field name="category"/>
                <field name="level" widget="badge"
                       decoration-success="level == 'info'"
                       decoration-warning="level == 'warning'"
                       decoration-danger="level == 'error'"/>
                <field name="summary"/>
                <field name="property_id" optional="show"/>
            </list>
        </field>
    </record>

    <record id="estate_kit_log_view_form" model="ir.ui.view">
        <field name="name">estate.kit.log.form</field>
        <field name="model">estate.kit.log</field>
        <field name="arch" type="xml">
            <form string="Лог" create="false" edit="false" delete="false">
                <sheet>
                    <group>
                        <group>
                            <field name="timestamp_display"/>
                            <field name="category"/>
                            <field name="level"/>
                        </group>
                        <group>
                            <field name="property_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="summary"/>
                    </group>
                    <group>
                        <field name="details"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="estate_kit_log_view_search" model="ir.ui.view">
        <field name="name">estate.kit.log.search</field>
        <field name="model">estate.kit.log</field>
        <field name="arch" type="xml">
            <search string="Поиск логов">
                <field name="summary"/>
                <field name="category"/>
                <field name="property_id"/>
                <separator/>
                <filter name="filter_info" string="Info" domain="[('level', '=', 'info')]"/>
                <filter name="filter_warning" string="Warning" domain="[('level', '=', 'warning')]"/>
                <filter name="filter_error" string="Error" domain="[('level', '=', 'error')]"/>
                <separator/>
                <filter name="group_category" string="Категория" context="{'group_by': 'category'}"/>
                <filter name="group_level" string="Уровень" context="{'group_by': 'level'}"/>
            </search>
        </field>
    </record>

    <record id="estate_kit_log_action" model="ir.actions.act_window">
        <field name="name">Логи</field>
        <field name="res_model">estate.kit.log</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
