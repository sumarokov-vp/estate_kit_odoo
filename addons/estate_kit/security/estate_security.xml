<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_estate" model="ir.module.category">
        <field name="name">Estate Kit</field>
        <field name="sequence">10</field>
    </record>

    <!-- ============================================================ -->
    <!-- Privileges (dropdown-селекторы в настройках пользователя)    -->
    <!-- ============================================================ -->

    <record id="privilege_estate_listing" model="res.groups.privilege">
        <field name="name">Листинг</field>
        <field name="sequence">10</field>
        <field name="category_id" ref="module_category_estate"/>
    </record>

    <record id="privilege_estate_marketing" model="res.groups.privilege">
        <field name="name">Маркетинг</field>
        <field name="sequence">20</field>
        <field name="category_id" ref="module_category_estate"/>
    </record>

    <!-- ============================================================ -->
    <!-- Группы: Листинг (линейная иерархия, каждый уровень implies   -->
    <!-- предыдущий — dropdown с 6 уровнями)                         -->
    <!-- ============================================================ -->

    <record id="group_estate_isa" model="res.groups">
        <field name="name">ISA</field>
        <field name="privilege_id" ref="privilege_estate_listing"/>
        <field name="sequence">10</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_estate_buyer_agent" model="res.groups">
        <field name="name">Buyer's Agent</field>
        <field name="privilege_id" ref="privilege_estate_listing"/>
        <field name="sequence">20</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('group_estate_isa'))]"/>
    </record>

    <record id="group_estate_transaction_coordinator" model="res.groups">
        <field name="name">Transaction Coordinator</field>
        <field name="privilege_id" ref="privilege_estate_listing"/>
        <field name="sequence">30</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('group_estate_buyer_agent'))]"/>
    </record>

    <record id="group_estate_listing_agent" model="res.groups">
        <field name="name">Listing Agent</field>
        <field name="privilege_id" ref="privilege_estate_listing"/>
        <field name="sequence">40</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('group_estate_transaction_coordinator'))]"/>
    </record>

    <record id="group_estate_listing_coordinator" model="res.groups">
        <field name="name">Listing Coordinator</field>
        <field name="privilege_id" ref="privilege_estate_listing"/>
        <field name="sequence">50</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('group_estate_listing_agent'))]"/>
    </record>

    <record id="group_estate_team_lead" model="res.groups">
        <field name="name">Team Lead</field>
        <field name="privilege_id" ref="privilege_estate_listing"/>
        <field name="sequence">60</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('group_estate_listing_coordinator'))]"/>
    </record>

    <!-- ============================================================ -->
    <!-- Группы: Маркетинг (линейная иерархия, 3 уровня)             -->
    <!-- ============================================================ -->

    <record id="group_estate_marketing_viewer" model="res.groups">
        <field name="name">Marketing Viewer</field>
        <field name="privilege_id" ref="privilege_estate_marketing"/>
        <field name="sequence">10</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_estate_marketing" model="res.groups">
        <field name="name">Marketing Manager</field>
        <field name="privilege_id" ref="privilege_estate_marketing"/>
        <field name="sequence">20</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('group_estate_marketing_viewer'))]"/>
    </record>

    <record id="group_estate_marketing_lead" model="res.groups">
        <field name="name">Team Lead</field>
        <field name="privilege_id" ref="privilege_estate_marketing"/>
        <field name="sequence">30</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('group_estate_marketing'))]"/>
    </record>

    <!-- ============================================================ -->
    <!-- Удаление старых привилегий (были checkbox, стали dropdown)   -->
    <!-- Удаляем все privilege в категории Estate Kit кроме новых      -->
    <!-- ============================================================ -->

    <delete model="res.groups.privilege" search="[('category_id.name', '=', 'Estate Kit'), ('name', 'not in', ['Листинг', 'Маркетинг'])]"/>

    <!-- Удаление старых групп из предыдущих версий -->
    <delete model="res.groups" search="[('name', 'in', ['User', 'Agent', 'Coordinator', 'Manager']), ('privilege_id.category_id.name', '=', 'Estate Kit')]"/>

    <!-- ============================================================ -->
    <!-- Record Rules для estate.property                            -->
    <!-- ============================================================ -->

    <record id="rule_property_team_lead" model="ir.rule">
        <field name="name">Team Lead: все записи</field>
        <field name="model_id" ref="model_estate_property"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('group_estate_team_lead'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="rule_property_listing_coordinator" model="ir.rule">
        <field name="name">Listing Coordinator: все записи</field>
        <field name="model_id" ref="model_estate_property"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('group_estate_listing_coordinator'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_property_transaction_coordinator" model="ir.rule">
        <field name="name">Transaction Coordinator: все записи (чтение)</field>
        <field name="model_id" ref="model_estate_property"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('group_estate_transaction_coordinator'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_property_listing_agent" model="ir.rule">
        <field name="name">Listing Agent: свои + открытые</field>
        <field name="model_id" ref="model_estate_property"/>
        <field name="domain_force">['|','|',('user_id','=',user.id),('listing_agent_id','=',user.id),('is_shared','=',True)]</field>
        <field name="groups" eval="[(4, ref('group_estate_listing_agent'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_property_buyer_agent" model="ir.rule">
        <field name="name">Buyer's Agent: опубликованные + свои</field>
        <field name="model_id" ref="model_estate_property"/>
        <field name="domain_force">['|',('state','=','published'),('user_id','=',user.id)]</field>
        <field name="groups" eval="[(4, ref('group_estate_buyer_agent'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_property_isa" model="ir.rule">
        <field name="name">ISA: опубликованные + свои</field>
        <field name="model_id" ref="model_estate_property"/>
        <field name="domain_force">['|',('state','=','published'),('user_id','=',user.id)]</field>
        <field name="groups" eval="[(4, ref('group_estate_isa'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_property_marketing" model="ir.rule">
        <field name="name">Marketing: все записи (чтение)</field>
        <field name="model_id" ref="model_estate_property"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('group_estate_marketing_viewer'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- ============================================================ -->
    <!-- Record Rules для estate.property.placement                  -->
    <!-- ============================================================ -->

    <record id="rule_placement_marketing_team_lead" model="ir.rule">
        <field name="name">Placement: Marketing Manager+ (полный CRUD)</field>
        <field name="model_id" ref="model_estate_property_placement"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('group_estate_marketing'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="rule_placement_others_readonly" model="ir.rule">
        <field name="name">Placement: все — только чтение</field>
        <field name="model_id" ref="model_estate_property_placement"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- ============================================================ -->
    <!-- Record Rules для estate.property.tier                       -->
    <!-- ============================================================ -->

    <record id="rule_tier_team_lead" model="ir.rule">
        <field name="name">Team Lead: все тир-листы</field>
        <field name="model_id" ref="model_estate_property_tier"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('group_estate_team_lead'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="rule_tier_listing_agent" model="ir.rule">
        <field name="name">Listing Agent: только свой тир-лист</field>
        <field name="model_id" ref="model_estate_property_tier"/>
        <field name="domain_force">[('user_id','=',user.id)]</field>
        <field name="groups" eval="[(4, ref('group_estate_listing_agent'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- ============================================================ -->
    <!-- Record Rules для estate.deal                                -->
    <!-- ============================================================ -->

    <record id="rule_deal_team_lead" model="ir.rule">
        <field name="name">Team Lead: все сделки</field>
        <field name="model_id" ref="model_estate_deal"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('group_estate_team_lead'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="rule_deal_listing_agent" model="ir.rule">
        <field name="name">Listing Agent: сделки со своим участием</field>
        <field name="model_id" ref="model_estate_deal"/>
        <field name="domain_force">[('participant_ids.user_id','=',user.id)]</field>
        <field name="groups" eval="[(4, ref('group_estate_listing_agent'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_deal_buyer_agent" model="ir.rule">
        <field name="name">Buyer's Agent: сделки со своим участием</field>
        <field name="model_id" ref="model_estate_deal"/>
        <field name="domain_force">[('participant_ids.user_id','=',user.id)]</field>
        <field name="groups" eval="[(4, ref('group_estate_buyer_agent'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- ============================================================ -->
    <!-- Record Rules для estate.deal.participant                    -->
    <!-- ============================================================ -->

    <record id="rule_deal_participant_team_lead" model="ir.rule">
        <field name="name">Team Lead: все участники сделок</field>
        <field name="model_id" ref="model_estate_deal_participant"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('group_estate_team_lead'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="rule_deal_participant_agent" model="ir.rule">
        <field name="name">Agent: участники своих сделок</field>
        <field name="model_id" ref="model_estate_deal_participant"/>
        <field name="domain_force">[('deal_id.participant_ids.user_id','=',user.id)]</field>
        <field name="groups" eval="[(4, ref('group_estate_listing_agent')), (4, ref('group_estate_buyer_agent'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- ============================================================ -->
    <!-- Record Rules для estate.lead.match                          -->
    <!-- ============================================================ -->

    <record id="rule_lead_match_team_lead" model="ir.rule">
        <field name="name">Team Lead: все матчи</field>
        <field name="model_id" ref="model_estate_lead_match"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('group_estate_team_lead'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="rule_lead_match_agent" model="ir.rule">
        <field name="name">Agent: матчи своих лидов</field>
        <field name="model_id" ref="model_estate_lead_match"/>
        <field name="domain_force">[('lead_id.user_id','=',user.id)]</field>
        <field name="groups" eval="[(4, ref('group_estate_listing_agent')), (4, ref('group_estate_buyer_agent'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

</odoo>
